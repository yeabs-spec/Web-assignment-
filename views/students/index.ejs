<%- include('../partials/header', { title }) %>
<%- include('../partials/nav') %>

<main class="card">
    <div class="section-head">
        <div>
            <h2>Student List</h2>
            <p>Manage student records with a simple PostgreSQL-backed CRUD app.</p>
        </div>
        <a class="button" href="/students/new">Add Student</a>
    </div>

    <% if (message) { %>
        <div class="alert success"><%= message %></div>
    <% } %>

    <% if (!students.length) { %>
        <div class="empty-state">
            <h3>No students yet</h3>
            <p>Add the first student to get started.</p>
        </div>
    <% } else { %>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Phone</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% students.forEach((student) => { %>
                        <tr>
                            <td><%= student.fullname %></td>
                            <td><%= student.email %></td>
                            <td><%= student.department %></td>
                            <td><%= student.phone || '-' %></td>
                            <td class="actions">
                                <a class="text-link" href="/students/<%= student.id %>/edit">Edit</a>
                                <form action="/students/<%= student.id %>/delete" method="POST" onsubmit="return confirm('Delete this student?');">
                                    <button type="submit" class="danger-link">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</main>

<%- include('../partials/footer') %>
