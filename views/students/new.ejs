<%- include('../partials/header', { title }) %>
<%- include('../partials/nav') %>

<main class="card narrow">
    <div class="section-head">
        <div>
            <h2>Add Student</h2>
            <p>Fill in a few details and save the record.</p>
        </div>
    </div>

    <% if (error) { %>
        <div class="alert error"><%= error %></div>
    <% } %>

    <form class="form-grid" action="/students" method="POST">
        <label>
            Full Name
            <input type="text" name="fullname" value="<%= student.fullname || '' %>" placeholder="John Doe" required>
        </label>
        <label>
            Email
            <input type="email" name="email" value="<%= student.email || '' %>" placeholder="john@example.com" required>
        </label>
        <label>
            Department
            <input type="text" name="department" value="<%= student.department || '' %>" placeholder="Computer Science" required>
        </label>
        <label>
            Phone
            <input type="text" name="phone" value="<%= student.phone || '' %>" placeholder="0912345678">
        </label>
        <div class="form-actions">
            <button class="button" type="submit">Save Student</button>
            <a class="secondary-button" href="/students">Cancel</a>
        </div>
    </form>
</main>

<%- include('../partials/footer') %>
