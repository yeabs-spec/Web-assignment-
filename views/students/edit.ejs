<%- include('../partials/header', { title }) %>
<%- include('../partials/nav') %>

<main class="card narrow">
    <div class="section-head">
        <div>
            <h2>Edit Student</h2>
            <p>Update the details and keep the record current.</p>
        </div>
    </div>

    <% if (error) { %>
        <div class="alert error"><%= error %></div>
    <% } %>

    <form class="form-grid" action="/students/<%= student.id %>" method="POST">
        <label>
            Full Name
            <input type="text" name="fullname" value="<%= student.fullname || '' %>" required>
        </label>
        <label>
            Email
            <input type="email" name="email" value="<%= student.email || '' %>" required>
        </label>
        <label>
            Department
            <input type="text" name="department" value="<%= student.department || '' %>" required>
        </label>
        <label>
            Phone
            <input type="text" name="phone" value="<%= student.phone || '' %>">
        </label>
        <div class="form-actions">
            <button class="button" type="submit">Update Student</button>
            <a class="secondary-button" href="/students">Back</a>
        </div>
    </form>
</main>

<%- include('../partials/footer') %>
