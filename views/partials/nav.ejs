<header class="topbar">
    <div>
        <p class="eyebrow">Simple project</p>
        <h1><a href="/students"><%= siteName %></a></h1>
    </div>
    <nav class="nav-links">
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
            <a class="<%= currentPath === '/students' ? 'active' : '' %>" href="/students">Students</a>
            <a class="<%= currentPath === '/students/new' ? 'active' : '' %>" href="/students/new">Add Student</a>
            <form action="/logout" method="POST" class="inline-form">
                <button type="submit" class="nav-button">Logout</button>
            </form>
        <% } else { %>
            <a class="<%= currentPath === '/login' ? 'active' : '' %>" href="/login">Login</a>
        <% } %>
    </nav>
</header>
